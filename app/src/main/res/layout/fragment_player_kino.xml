<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- The actual video surface -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false" />

    <!-- Controls Overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/controls_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#4D000000">

        <!-- Top Bar -->
        <LinearLayout
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/back_button"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_glass"
                android:src="@drawable/ic_baseline_arrow_back_24"
                app:tint="#FFFFFF" />

            <TextView
                android:id="@+id/player_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Content Title"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/player_settings"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@transparent"
                android:src="@drawable/ic_baseline_settings_24"
                app:tint="#FFFFFF" />
        </LinearLayout>

        <!-- Center Controls -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/rewind_10"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@transparent"
                android:src="@drawable/ic_baseline_replay_10_24"
                app:tint="#FFFFFF" />

            <ImageButton
                android:id="@+id/play_pause_button"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginHorizontal="48dp"
                android:background="@drawable/bg_circle_red"
                android:padding="16dp"
                android:src="@drawable/ic_baseline_play_arrow_24"
                app:tint="#FFFFFF" />

            <ImageButton
                android:id="@+id/forward_10"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@transparent"
                android:src="@drawable/ic_baseline_forward_10_24"
                app:tint="#FFFFFF" />
        </LinearLayout>

        <!-- Bottom Bar -->
        <LinearLayout
            android:id="@+id/bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.slider.Slider
                android:id="@+id/progress_slider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0"
                android:valueTo="100"
                app:thumbColor="#E50914"
                app:trackColorActive="#E50914"
                app:trackColorInactive="#4DFFFFFF" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/current_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/total_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="00:00"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/subtitle_selector"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@transparent"
                    android:src="@drawable/ic_baseline_closed_caption_24"
                    app:tint="#FFFFFF" />

                <ImageButton
                    android:id="@+id/audio_selector"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="16dp"
                    android:background="@transparent"
                    android:src="@drawable/ic_baseline_audiotrack_24"
                    app:tint="#FFFFFF" />

                <ImageButton
                    android:id="@+id/quality_selector"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="16dp"
                    android:background="@transparent"
                    android:src="@drawable/ic_baseline_hd_24"
                    app:tint="#FFFFFF" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/speed_selector"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@transparent"
                    android:src="@drawable/ic_baseline_speed_24"
                    app:tint="#FFFFFF" />

                <ImageButton
                    android:id="@+id/pip_button"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="16dp"
                    android:background="@transparent"
                    android:src="@drawable/ic_baseline_picture_in_picture_24"
                    app:tint="#FFFFFF" />

                <ImageButton
                    android:id="@+id/lock_button"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="16dp"
                    android:background="@transparent"
                    android:src="@drawable/ic_baseline_lock_open_24"
                    app:tint="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <!-- Gesture Overlays (Brightness/Volume) -->
        <FrameLayout
            android:id="@+id/brightness_overlay"
            android:layout_width="64dp"
            android:layout_height="200dp"
            android:layout_marginStart="32dp"
            android:background="@drawable/bg_gesture_bar"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <!-- Brightness bar implementation -->
        </FrameLayout>

        <FrameLayout
            android:id="@+id/volume_overlay"
            android:layout_width="64dp"
            android:layout_height="200dp"
            android:layout_marginEnd="32dp"
            android:background="@drawable/bg_gesture_bar"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <!-- Volume bar implementation -->
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
